{
  "name": "sportsee",
  "version": "1.0.0",
  "description": "SportSee sports analytics dashboard",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx api/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\"",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,tsx,css,scss}\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.3.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^15.0.0",
    "html-validate": "^10.9.0",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.0.0",
    "rollup-plugin-visualizer": "7.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-order": "^6.0.0",
    "ts-api-utils": "^2.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.6.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^6.0.0"
  },
  "overrides": {
    "glob": "^13.0.0",
    "source-map": "^0.7.4",
    "magic-string": "^0.30.0",
    "serialize-javascript": "^7.0.3",
    "tmp": "^0.2.5"
  }
}
